          "background": { "solid": { "color": "#1C2636" } }
        }]
      }
    },
    "card": {
      "*": {
        "background": [{ "show": true, "color": { "solid": { "color": "#111827" } } }],
        "border": [{ "show": true, "color": { "solid": { "color": "#374459" } }, "radius": 4 }],
        "labels": [{ "color": { "solid": { "color": "#E7E5E0" } }, "fontFamily": "Barlow Thin", "fontSize": 28 }],
        "categoryLabels": [{ "color": { "solid": { "color": "#96928A" } }, "fontFamily": "Barlow", "fontSize": 10 }]
      }
    },
    "page": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#111827" } }, "transparency": 0 }],
        "outspace": [{ "color": { "solid": { "color": "#080C12" } }, "transparency": 0 }]
      }
