    "title": { "fontFace": "Cormorant Garamond SemiBold", "fontSize": 18, "color": "#E7E5E0" },
    "header": { "fontFace": "Barlow", "fontSize": 12, "color": "#E7E5E0" },
    "callout": { "fontFace": "Barlow Thin", "fontSize": 28, "color": "#E7E5E0" },
    "label": { "fontFace": "Barlow", "fontSize": 10, "color": "#96928A" }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{ "show": true, "color": { "solid": { "color": "#1C2636" } } }],
        "border": [{ "show": true, "color": { "solid": { "color": "#374459" } }, "radius": 4 }],
        "visualHeaderTooltip": [{ "background": { "solid": { "color": "#111827" } } }],
